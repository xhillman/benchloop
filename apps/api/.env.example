# FastAPI runtime defaults for local development.
BENCHLOOP_ENV=local
BENCHLOOP_LOG_LEVEL=INFO
BENCHLOOP_HOST=0.0.0.0
BENCHLOOP_PORT=8000
BENCHLOOP_DATABASE_URL=postgresql+psycopg://benchloop:benchloop@localhost:5432/benchloop
BENCHLOOP_DB_ECHO=false

# Reserve the secret shape now so credential encryption lands on a fixed env contract.
BENCHLOOP_ENCRYPTION_KEY=replace-with-long-random-app-secret

# Future auth and browser access placeholders.
BENCHLOOP_CORS_ALLOWED_ORIGINS=["http://localhost:3000"]
CLERK_SECRET_KEY=sk_test_replace_me
CLERK_JWKS_URL=https://clerk.example.com/.well-known/jwks.json
CLERK_JWT_ISSUER=https://clerk.example.com
CLERK_JWT_AUDIENCE=benchloop
CLERK_JWKS_CACHE_TTL_SECONDS=300
